pipeline {
    agent any

    stages {
        stage('Install Dependencies') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'npm install'
                        sh 'npx playwright install'
                    } else {
                        bat 'npm install'
                        bat 'npx playwright install'
                    }
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    def status
                    if (isUnix()) {
                        status = sh(script: 'npx playwright test --reporter=html', returnStatus: true)
                    } else {
                        status = bat(script: 'npx playwright test --reporter=html', returnStatus: true)
                    }
                    if (status != 0) {
                        echo "Tests failed, but continuing to generate reports..."
                    }
                }
            }
        }
    }

    post {
        always {
            echo 'Generating HTML reports...'
//             publishHTML(target: [
//                 reportDir: 'playwright-report',
//                 reportFiles: 'index.html',
//                 reportName: 'Playwright HTML Report',
//                 alwaysLinkToLastBuild: true,
//                 keepAll: true,
//                 allowMissing: true,
//                 linkRelative: false
//             ])
//             archiveArtifacts artifacts: 'Screenshots/**, test-results/**', allowEmptyArchive: true
        }
    }
}
